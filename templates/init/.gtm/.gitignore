# Secrets - never commit
config.json

# Large binary files
creatives/*.png
creatives/*.jpg
creatives/**/*.png
creatives/**/*.jpg

# HVA creative binaries and raw read snapshots (noisy/large).
# Keep manifests, decisions, audit logs, and the Vault — that data is the moat.
hva/**/*.png
hva/**/*.jpg
hva/**/reads/snapshot-*.json

# SDV raw reaction dumps and embedding caches (noisy/large).
# Keep forecasts, anchors, and calibration pairs — that data grounds future runs.
sdv/**/reactions-*.json
sdv/**/embeddings-cache.json

# Everything else is safe to commit
